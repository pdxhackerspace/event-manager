# Development (local or Docker: docker compose -f docker-compose.dev.yml)
# Copy to .env for Compose variable substitution, or merge into your shell environment.
#
#   cp .env.development.example .env

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
RAILS_ENV=development
TZ=America/Los_Angeles

# Match docker-compose.dev.yml db/redis service names when using Compose
DATABASE_HOST=db
DATABASE_USER=eventmanager
DATABASE_PASSWORD=eventmanager_password
DATABASE_NAME=EventManager_development

REDIS_URL=redis://redis:6379/0

# Optional: run seeds on empty DB (see docker-entrypoint.sh / compose command)
# RUN_MIGRATIONS=true

# -----------------------------------------------------------------------------
# Rails / Puma
# -----------------------------------------------------------------------------
RAILS_MAX_THREADS=5
RAILS_MIN_THREADS=5
PORT=3000
# RAILS_HOST is used in mailers and URLs (use host:port when not using default 80/443)
RAILS_HOST=localhost:3000
RAILS_PROTOCOL=http
RAILS_PORT=3000

# -----------------------------------------------------------------------------
# Secrets (generate for non-Docker local runs: bin/rails secret)
# -----------------------------------------------------------------------------
# SECRET_KEY_BASE=

# -----------------------------------------------------------------------------
# Authentik OAuth (optional — leave blank for password-only flows in dev)
# -----------------------------------------------------------------------------
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_SITE_URL=http://localhost:9000

# -----------------------------------------------------------------------------
# Email — set SMTP_* to send real mail; otherwise development uses :test delivery
# -----------------------------------------------------------------------------
# SMTP_ADDRESS=
# SMTP_PORT=587
# SMTP_DOMAIN=
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_AUTHENTICATION=plain
# SMTP_ENABLE_STARTTLS=true
MAILER_FROM_EMAIL=noreply@example.com

# -----------------------------------------------------------------------------
# Integrations (optional)
# -----------------------------------------------------------------------------
# SLACK_WEBHOOK_URL=
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=development
# OLLAMA_SERVER=
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_ACCOUNT_ID=
# BLUESKY_HANDLE=
# BLUESKY_APP_PASSWORD=

# APP_HOST=localhost:3000
