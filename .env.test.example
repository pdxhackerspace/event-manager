# Test (CI or Docker: docker compose -f docker-compose.test.yml)
# Compose loads .env automatically; for CI, set these in the workflow or job env.
#
#   cp .env.test.example .env

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
RAILS_ENV=test
TZ=America/Los_Angeles
DISABLE_SPRING=1

# Optional: eager-load the app in CI for parity with production boot
# CI=true

# Inside the test Compose network, db/redis hostnames match service names
DATABASE_HOST=db
DATABASE_USER=eventmanager
DATABASE_PASSWORD=eventmanager_password
DATABASE_NAME=EventManager_test

REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Rails / Puma
# -----------------------------------------------------------------------------
RAILS_MAX_THREADS=5

# -----------------------------------------------------------------------------
# Secrets — CI often injects a dummy key for asset or integration steps
# -----------------------------------------------------------------------------
# SECRET_KEY_BASE=dummy_secret_key_base_for_test

# -----------------------------------------------------------------------------
# Authentik (only if system tests hit OAuth; usually omitted)
# -----------------------------------------------------------------------------
# AUTHENTIK_CLIENT_ID=
# AUTHENTIK_CLIENT_SECRET=
# AUTHENTIK_SITE_URL=http://localhost:9000

# Most tests do not send mail; omit SMTP unless needed
