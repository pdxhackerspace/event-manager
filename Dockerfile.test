# syntax=docker/dockerfile:1.4
# ========================================
# Dockerfile for running tests, rubocop, and migrations
# Includes development and test gems (unlike production Dockerfile)
# ========================================
FROM ruby:3.3.11

# Install build dependencies
# ImageMagick: Debian metapackage; apt-get update picks up current security/main versions at build time
RUN apt-get update -qq && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    curl \
    gnupg \
    git \
    imagemagick \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 20.x LTS and Yarn 1.x (Classic) via Corepack (avoids deprecated apt-key Yarn repo)
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - && \
    apt-get update -qq && apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/* && \
    corepack enable && corepack prepare yarn@1.22.22 --activate

WORKDIR /app

# Copy dependency files first (for better layer caching)
COPY Gemfile Gemfile.lock ./
COPY package.json yarn.lock* ./

# Install ALL Ruby gems (including development and test)
RUN bundle config set --local without '' && \
    bundle install --jobs 4 --retry 3

# Install Node modules
RUN yarn install --frozen-lockfile

# Copy application code
COPY . .

# Build assets
RUN yarn build && yarn build:css

# Default command
CMD ["bin/rails", "console"]

