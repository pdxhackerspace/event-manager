# Production (docker-compose.yml or bare-metal with same env contract)
# Copy on the server: cp .env.production.example .env
#
# Never commit real secrets; chmod 600 .env on the host.

RAILS_ENV=production
TZ=America/Los_Angeles
RAILS_LOG_TO_STDOUT=true
RAILS_SERVE_STATIC_FILES=true

# Public host for mailers, Slack links, etc.
RAILS_HOST=events.example.com
RAILS_PROTOCOL=https

# Injected at image build; optional runtime override
# APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Secrets
# -----------------------------------------------------------------------------
SECRET_KEY_BASE=generate_with_bin_rails_secret

# -----------------------------------------------------------------------------
# Database — docker-compose builds DATABASE_URL from these; docker-entrypoint
# uses DATABASE_HOST / DATABASE_USER / DATABASE_PASSWORD for the wait loop.
# -----------------------------------------------------------------------------
DATABASE_HOST=db
DATABASE_USER=EventManager
DATABASE_PASSWORD=change_me_strong_password
DATABASE_NAME=EventManager_production
DATABASE_URL=postgres://EventManager:change_me_strong_password@db/EventManager_production
# database.yml production password (if not using DATABASE_URL alone):
EVENTMANAGER_DATABASE_PASSWORD=change_me_strong_password

REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Authentik OAuth
# -----------------------------------------------------------------------------
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_SITE_URL=https://authentik.example.com

# -----------------------------------------------------------------------------
# Outbound email (production delivery)
# -----------------------------------------------------------------------------
SMTP_ADDRESS=smtp.example.com
SMTP_PORT=587
SMTP_DOMAIN=events.example.com
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS=true
MAILER_FROM_EMAIL=noreply@events.example.com

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
RAILS_MAX_THREADS=5
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SLACK_WEBHOOK_URL=
# OLLAMA_SERVER=
# INSTAGRAM_* / BLUESKY_* — see .env.development.example
