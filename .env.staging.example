# Staging (RAILS_ENV=staging — production-like, mail captured via Letter Opener Web)
# Copy on the staging host, e.g. cp .env.staging.example .env
#
# Public URL for mail links and OAuth callbacks:
RAILS_HOST=staging.example.com
RAILS_PROTOCOL=https

RAILS_ENV=staging
TZ=America/Los_Angeles
RAILS_LOG_TO_STDOUT=true
# Serve precompiled assets when fronting with a reverse proxy
RAILS_SERVE_STATIC_FILES=true

# Injected at image build in CI; optional override at runtime
# APP_VERSION=0.15.0

# -----------------------------------------------------------------------------
# Secrets
# -----------------------------------------------------------------------------
SECRET_KEY_BASE=generate_with_bin_rails_secret

# -----------------------------------------------------------------------------
# Database — Rails uses username "EventManager" + EVENTMANAGER_DATABASE_PASSWORD
# (see config/database.yml). Postgres container user must match or use DATABASE_URL.
# docker-entrypoint waits on DATABASE_HOST / DATABASE_USER / DATABASE_PASSWORD.
# -----------------------------------------------------------------------------
DATABASE_HOST=db
DATABASE_USER=EventManager
DATABASE_PASSWORD=change_me
DATABASE_NAME=EventManager_staging
EVENTMANAGER_DATABASE_PASSWORD=change_me
# DATABASE_URL=postgres://EventManager:change_me@db/EventManager_staging

REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Authentik OAuth (use your staging IdP application)
# -----------------------------------------------------------------------------
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_SITE_URL=https://authentik-staging.example.com

# -----------------------------------------------------------------------------
# Email — staging uses letter_opener_web; no SMTP required for capture.
# Uncomment if you intentionally send real mail from staging.
# -----------------------------------------------------------------------------
# SMTP_ADDRESS=
# SMTP_PORT=587
# SMTP_DOMAIN=
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_AUTHENTICATION=plain
# SMTP_ENABLE_STARTTLS=true
MAILER_FROM_EMAIL=noreply@staging.example.com

# -----------------------------------------------------------------------------
# Optional observability & features
# -----------------------------------------------------------------------------
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=staging
# SLACK_WEBHOOK_URL=
# OLLAMA_SERVER=

RAILS_MAX_THREADS=5
